package com.example.n2;

import android.app.AlertDialog;
import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
import java.util.ArrayList;

public class MainActivity extends AppCompatActivity {

    EditText etAmount, etDescription;
    Spinner spCategory;
    RadioGroup radioGroupPayment;
    ListView listView;

    ArrayList<String> expenseList;
    ArrayAdapter<String> listAdapter;

    String accountantPhone = "9876543210";

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        etAmount = findViewById(R.id.etAmount);
        etDescription = findViewById(R.id.etDescription);
        spCategory = findViewById(R.id.spCategory);
        radioGroupPayment = findViewById(R.id.radioGroupPayment);
        listView = findViewById(R.id.listView);

        Button btnAdd = findViewById(R.id.btnAdd);
        Button btnCall = findViewById(R.id.btnCall);
        Button btnSMS = findViewById(R.id.btnSMS);
        Button btnEmail = findViewById(R.id.btnEmail);

        // Spinner data
        String[] categories = {
                "Office Supplies",
                "Travel / Taxi",
                "Client Meeting",
                "Printing / Xerox",
                "Internet / Phone Bill"
        };

        ArrayAdapter<String> spinnerAdapter = new ArrayAdapter<>(
                this, android.R.layout.simple_spinner_dropdown_item, categories);
        spCategory.setAdapter(spinnerAdapter);

        // List setup
        expenseList = new ArrayList<>();
        listAdapter = new ArrayAdapter<>(
                this, android.R.layout.simple_list_item_1, expenseList);
        listView.setAdapter(listAdapter);

        // Add expense
        btnAdd.setOnClickListener(v -> {
            String amount = etAmount.getText().toString();
            String desc = etDescription.getText().toString();
            String category = spCategory.getSelectedItem().toString();

            int id = radioGroupPayment.getCheckedRadioButtonId();
            RadioButton rb = findViewById(id);
            String payment = rb != null ? rb.getText().toString() : "";

            String record = desc + " - $" + amount + " (" + category + ", " + payment + ")";
            expenseList.add(record);
            listAdapter.notifyDataSetChanged();

            etAmount.setText("");
            etDescription.setText("");
        });

        // Call
        btnCall.setOnClickListener(v -> showConfirm("call"));

        // SMS
        btnSMS.setOnClickListener(v -> showConfirm("sms"));

        // Email
        btnEmail.setOnClickListener(v -> {
            Intent emailIntent = new Intent(Intent.ACTION_SENDTO);
            emailIntent.setData(Uri.parse("mailto:accountant@gmail.com"));
            emailIntent.putExtra(Intent.EXTRA_SUBJECT, "Daily Expense Report");
            startActivity(emailIntent);
        });
    }

    private void showConfirm(String type) {
        new AlertDialog.Builder(this)
                .setTitle("Confirm")
                .setMessage("Do you want to proceed?")
                .setPositiveButton("Yes", (d, w) -> {
                    if (type.equals("call")) {
                        startActivity(new Intent(Intent.ACTION_DIAL,
                                Uri.parse("tel:" + accountantPhone)));
                    } else {
                        startActivity(new Intent(Intent.ACTION_VIEW,
                                Uri.parse("sms:" + accountantPhone)));
                    }
                })
                .setNegativeButton("Cancel", null)
                .show();
    }
}






