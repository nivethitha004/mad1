package com.example.n1;

import android.app.AlertDialog;
import android.app.DatePickerDialog;
import android.content.Intent;
import android.net.Uri;
import android.os.Bundle;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;
import java.util.Calendar;

public class MainActivity extends AppCompatActivity {

    EditText etName, etAge, etPhone;
    RadioGroup radioGroupGender;
    Spinner spIllness;
    TextView tvDate, tvDetails;

    String selectedDate = "";
    String doctorPhone = "9876543210";

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // Bind views
        etName = findViewById(R.id.etName);
        etAge = findViewById(R.id.etAge);
        etPhone = findViewById(R.id.etPhone);
        radioGroupGender = findViewById(R.id.radioGroupGender);
        spIllness = findViewById(R.id.spIllness);
        tvDate = findViewById(R.id.tvDate);
        tvDetails = findViewById(R.id.tvDetails);

        Button btnDate = findViewById(R.id.btnDate);
        Button btnSubmit = findViewById(R.id.btnSubmit);
        Button btnCall = findViewById(R.id.btnCall);
        Button btnSMS = findViewById(R.id.btnSMS);
        Button btnEmail = findViewById(R.id.btnEmail);

        // Spinner data
        String[] illness = {"Fever", "Cold", "Headache", "Diabetes"};
        ArrayAdapter<String> adapter = new ArrayAdapter<>(
                this,
                android.R.layout.simple_spinner_dropdown_item,
                illness);
        spIllness.setAdapter(adapter);

        // Date picker
        btnDate.setOnClickListener(v -> {
            Calendar cal = Calendar.getInstance();
            DatePickerDialog dp = new DatePickerDialog(
                    MainActivity.this,
                    (view, year, month, day) -> {
                        selectedDate = day + "/" + (month + 1) + "/" + year;
                        tvDate.setText(selectedDate);
                    },
                    cal.get(Calendar.YEAR),
                    cal.get(Calendar.MONTH),
                    cal.get(Calendar.DAY_OF_MONTH)
            );
            dp.show();
        });

        // Submit button
        btnSubmit.setOnClickListener(v -> {

            int selectedId = radioGroupGender.getCheckedRadioButtonId();
            String gender = "Not selected";

            if (selectedId != -1) {
                RadioButton rb = findViewById(selectedId);
                gender = rb.getText().toString();
            }

            String details =
                    "Name: " + etName.getText().toString() + "\n" +
                            "Age: " + etAge.getText().toString() + "\n" +
                            "Phone: " + etPhone.getText().toString() + "\n" +
                            "Gender: " + gender + "\n" +
                            "Illness: " + spIllness.getSelectedItem().toString() + "\n" +
                            "Date: " + selectedDate;

            tvDetails.setText(details);
        });

        // Call
        btnCall.setOnClickListener(v -> showConfirm("call"));

        // SMS
        btnSMS.setOnClickListener(v -> showConfirm("sms"));

        // Email
        btnEmail.setOnClickListener(v -> {
            Intent emailIntent = new Intent(Intent.ACTION_SENDTO);
            emailIntent.setData(Uri.parse("mailto:doctor@gmail.com"));
            emailIntent.putExtra(Intent.EXTRA_SUBJECT, "Patient Appointment");

            startActivity(Intent.createChooser(emailIntent, "Send Email"));
        });
    }

    private void showConfirm(String type) {
        new AlertDialog.Builder(this)
                .setTitle("Confirmation")
                .setMessage("Do you want to proceed?")
                .setPositiveButton("Yes", (d, w) -> {

                    if (type.equals("call")) {
                        Intent intent = new Intent(Intent.ACTION_DIAL);
                        intent.setData(Uri.parse("tel:" + doctorPhone));
                        startActivity(intent);
                    }

                    else if (type.equals("sms")) {
                        Intent intent = new Intent(Intent.ACTION_SENDTO);
                        intent.setData(Uri.parse("smsto:" + doctorPhone));
                        startActivity(intent);
                    }
                })
                .setNegativeButton("No", null)
                .show();
    }
}







    
